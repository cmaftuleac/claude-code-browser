{
  "name": "claude-code-browser",
  "version": "0.1.0",
  "description": "Claude Code Browser - Connect Chrome to Claude Code for visual web debugging",
  "author": "Corneliu Maftuleac (https://x.com/cmaftuleac)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmaftuleac/claude-code-browser.git"
  },
  "homepage": "https://github.com/cmaftuleac/claude-code-browser",
  "keywords": [
    "claude",
    "claude-code",
    "chrome-extension",
    "browser",
    "web-debugging",
    "native-messaging",
    "element-picker",
    "anthropic"
  ],
  "bin": {
    "claude-code-browser": "./dist/install.js"
  },
  "type": "module",
  "files": [
    "dist/",
    "skills/"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path').join(__dirname,'dist','host.js'),c=fs.readFileSync(p,'utf8');fs.writeFileSync(p,c.replace(/^#!.*\\n/,'#!'+process.execPath+'\\n'));fs.chmodSync(p,'755');fs.writeFileSync(require('path').join(__dirname,'dist','install.js'),fs.readFileSync(require('path').join(__dirname,'dist','install.js'),'utf8').replace(/^#!.*\\n/,'#!'+process.execPath+'\\n'));fs.chmodSync(require('path').join(__dirname,'dist','install.js'),'755')\" && echo '{\"type\":\"module\"}' > dist/package.json",
    "dev": "tsx src/host.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.87"
  },
  "devDependencies": {
    "@claude-code-browser/shared": "*",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0"
  }
}
